{
  "name": "viewer-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "types": "./src/index.ts",
  "scripts": {
    "dev": "npm run prepare-assets && vite",
    "build": "tsc && npm run prepare-assets && vite build",
    "test": "npm run prepare-copc-wasm && node --import tsx --test test/copc-reader.test.mjs",
    "preview": "vite preview",
    "prepare-assets": "npm run prepare-copc-wasm && npm run prepare-laz-perf",
    "prepare-copc-wasm": "node scripts/build-copc-wasm.mjs",
    "prepare-laz-perf": "cp node_modules/laz-perf/lib/laz-perf.wasm public/laz-perf.wasm"
  },
  "devDependencies": {
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "vite-plugin-cesium": "^1.2.23",
    "vite-plugin-static-copy": "^4.1.1"
  },
  "dependencies": {
    "cesium": "^1.142.0",
    "copc": "^0.0.8",
    "proj4": "^2.20.9"
  }
}
